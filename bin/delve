#!/usr/bin/env python3
"""delve — roguebash CLI

Subcommands:

  delve start                   # easy-mode: check backend + new-or-resume + play
  delve new  [--scenario N] [--seed N] [--name N] [--class C] [--race R]
             [--macro-nodes N]
  delve play [<run-id>]
  delve list
  delve show [<run-id>]
  delve abandon <run-id>
  delve help

Reads optional config from $XDG_CONFIG_HOME/roguebash/delve.toml or
./delve.toml. CLI flags override config.

Implementation lives in engine.cli.*; this file is just argparse +
dispatch.
"""

from __future__ import annotations

import argparse
import sys
from pathlib import Path

# Make the repo root importable so `from engine...` works when `delve`
# is invoked from anywhere (e.g. via a symlink in ~/.local/bin).
_THIS = Path(__file__).resolve()
_REPO_ROOT = _THIS.parent.parent
if str(_REPO_ROOT) not in sys.path:
    sys.path.insert(0, str(_REPO_ROOT))

from engine.cli import commands  # noqa: E402
from engine.cli.config import load_config  # noqa: E402


def build_parser() -> argparse.ArgumentParser:
    p = argparse.ArgumentParser(prog="delve", add_help=False)
    sub = p.add_subparsers(dest="cmd")

    sub.add_parser("start", add_help=False)

    new = sub.add_parser("new", add_help=False)
    new.add_argument("--scenario", default=None)
    new.add_argument("--seed", type=int, default=None)
    new.add_argument("--name", default=None)
    new.add_argument("--class", dest="cls", default="ranger")
    new.add_argument("--race", default="halfling")
    new.add_argument("--macro-nodes", type=int, default=None)

    play = sub.add_parser("play", add_help=False)
    play.add_argument("run_id", nargs="?", default=None)

    sub.add_parser("list", add_help=False)

    show = sub.add_parser("show", add_help=False)
    show.add_argument("run_id", nargs="?", default=None)

    abandon = sub.add_parser("abandon", add_help=False)
    abandon.add_argument("run_id")

    sub.add_parser("help", add_help=False)
    return p


_DISPATCH = {
    "start":   commands.cmd_start,
    "new":     commands.cmd_new,
    "play":    commands.cmd_play,
    "list":    commands.cmd_list,
    "show":    commands.cmd_show,
    "abandon": commands.cmd_abandon,
}


def main(argv: list[str] | None = None) -> int:
    argv = argv if argv is not None else sys.argv[1:]
    args = build_parser().parse_args(argv)
    cfg = load_config(_REPO_ROOT)

    if args.cmd in _DISPATCH:
        return _DISPATCH[args.cmd](args, cfg, _REPO_ROOT)

    # help / no subcommand
    print(__doc__.strip())
    return 0


if __name__ == "__main__":
    sys.exit(main())

#!/bin/bash
# look — describe the current room: short_desc, known exits, visible
# items/NPCs/monsters. The DM (caller) uses this to narrate.
set -euo pipefail

SELF="$(readlink -f "${BASH_SOURCE[0]}" 2>/dev/null || realpath "${BASH_SOURCE[0]}")"
HERE="$(dirname "$SELF")"

if [ "${1:-}" = "--schema" ]; then
  cat <<'JSON'
{
  "name": "look",
  "description": "Describe the current room: short description, known exits, and visible items, NPCs, and monsters. Call this to orient after movement or when the player asks to look around.",
  "parameters": {
    "type": "object",
    "properties": {},
    "required": []
  }
}
JSON
  exit 0
fi

# shellcheck source=../_shared/common.sh
source "$HERE/../_shared/common.sh"
rb_read_args
rb_run_py "$HERE/look.py"

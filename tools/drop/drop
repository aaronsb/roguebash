#!/bin/bash
# drop — move an item from the character's inventory into the current room.
set -euo pipefail

SELF="$(readlink -f "${BASH_SOURCE[0]}" 2>/dev/null || realpath "${BASH_SOURCE[0]}")"
HERE="$(dirname "$SELF")"

if [ "${1:-}" = "--schema" ]; then
  cat <<'JSON'
{
  "name": "drop",
  "description": "Drop an item from inventory onto the floor of the current room. Fails if the item is not carried.",
  "parameters": {
    "type": "object",
    "properties": {
      "item_ref": {
        "type": "string",
        "description": "Canonical item id, e.g. 'item.lantern'."
      }
    },
    "required": ["item_ref"]
  }
}
JSON
  exit 0
fi

# shellcheck source=../_shared/common.sh
source "$HERE/../_shared/common.sh"
rb_read_args
rb_run_py "$HERE/drop.py"

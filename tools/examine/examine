#!/bin/bash
# examine — deeper description of a room, item (in room or inventory),
# NPC, or monster.
set -euo pipefail

SELF="$(readlink -f "${BASH_SOURCE[0]}" 2>/dev/null || realpath "${BASH_SOURCE[0]}")"
HERE="$(dirname "$SELF")"

if [ "${1:-}" = "--schema" ]; then
  cat <<'JSON'
{
  "name": "examine",
  "description": "Give a deeper description of a target: a room (id or 'room'), an item (by id, in the room or in inventory), an NPC, or a monster. Returns long_desc + tags/dialog_hooks/HP-status where relevant.",
  "parameters": {
    "type": "object",
    "properties": {
      "target": {
        "type": "string",
        "description": "Target identifier: a room id, item.<id>, npc.<id>, monster.<id>, or the literal 'room' / 'here' for the current room."
      }
    },
    "required": ["target"]
  }
}
JSON
  exit 0
fi

# shellcheck source=../_shared/common.sh
source "$HERE/../_shared/common.sh"
rb_read_args
rb_run_py "$HERE/examine.py"

#!/bin/bash
# adapter: local — wraps the `agent` script from the sibling agent-bash
# project: https://github.com/aaronsb/agent-bash
#
# Reads the roguebash context from env and delegates.
set -euo pipefail

: "${ROGUEBASH_SYSTEM_PROMPT:?}"
: "${ROGUEBASH_USER_MESSAGE:?}"
: "${ROGUEBASH_TOOLS_DIR:?}"
: "${ROGUEBASH_MAX_TURNS:=12}"

# The `agent` script expects tools under ./tools next to itself.
# We temporarily point it at our roguebash tools/ by running it from a
# scratch cwd that symlinks tools/ into place.

AGENT_BIN="$(command -v agent || true)"
if [ -z "$AGENT_BIN" ] || [ ! -x "$AGENT_BIN" ]; then
  cat >&2 <<MSG
adapter/local: can't find the 'agent' binary.

Install the sibling agent-bash project:
    git clone git@github.com:aaronsb/agent-bash.git ~/Projects/agent-bash
    ln -s ~/Projects/agent-bash/agent ~/.local/bin/agent
    ln -s ~/Projects/agent-bash/askd  ~/.local/bin/askd
    ln -s ~/Projects/agent-bash/ask   ~/.local/bin/ask
    askd download && askd start

Or set AGENT_BIN=/path/to/agent in your environment.
MSG
  exit 127
fi

SCRATCH="$(mktemp -d)"
trap 'rm -rf "$SCRATCH"' EXIT
ln -s "$ROGUEBASH_TOOLS_DIR" "$SCRATCH/tools"

# agent composes its own user prompt; we prepend the system prompt as a
# lead-in paragraph because it currently takes only a user message.
# (When agent gains native --system flag support, switch to that.)
PROMPT="$ROGUEBASH_SYSTEM_PROMPT

---

Player input:
$ROGUEBASH_USER_MESSAGE"

cd "$SCRATCH"
exec "$AGENT_BIN" -n "$ROGUEBASH_MAX_TURNS" -q "$PROMPT"
